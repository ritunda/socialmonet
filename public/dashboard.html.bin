<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SocialMonet Dashboard</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-functions-compat.js"></script>
    <script src="firebase-config.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <div class="header">
            <h1>SocialMonet Dashboard</h1>
            <button onclick="logout()" class="logout-btn">Logout</button>
        </div>
        
        <div class="stats-grid" id="stats-grid">
            <div class="stat-card">
                <h3>📊 Status</h3>
                <p id="status">Checking...</p>
            </div>
            <div class="stat-card">
                <h3>👍 Best Post Likes</h3>
                <p id="best-likes">0</p>
            </div>
            <div class="stat-card">
                <h3>💰 Total Earned</h3>
                <p id="total-earned">$0</p>
            </div>
            <div class="stat-card">
                <h3>💵 Pending Balance</h3>
                <p id="pending-balance">$0</p>
            </div>
        </div>
        
        <div class="section" id="connect-section">
            <h2>🔗 Connect Facebook</h2>
            <p>We need to check if you have a post with 100+ likes</p>
            <button onclick="connectFacebook()" id="connect-btn">Connect Facebook Account</button>
            <div id="connect-status"></div>
        </div>
        
        <div class="section" id="campaigns-section" style="display:none;">
            <h2>📢 Available Campaigns</h2>
            <div id="campaigns-list"></div>
        </div>
        
        <div class="section" id="ad-submit-section" style="display:none;">
            <h2>📝 Submit Ad Post</h2>
            <select id="campaign-select"></select>
            <input type="url" id="post-url" placeholder="Paste your Facebook post URL here">
            <button onclick="submitAd()">Submit for Tracking</button>
            <div id="submit-status"></div>
        </div>
        
        <div class="section" id="earnings-section" style="display:none;">
            <h2>📈 Recent Earnings</h2>
            <div id="earnings-list"></div>
            <button onclick="requestWithdrawal()" id="withdraw-btn" class="withdraw-btn">Withdraw (min $20)</button>
        </div>
    </div>
    
    <script>
        let currentUser = null;
        let functions = null;
        let availableCampaigns = [];
        
        auth.onAuthStateChanged(async (user) => {
            if (!user) {
                window.location.href = 'index.html';
                return;
            }
            currentUser = user;
            functions = firebase.functions();
            loadStats();
        });
        
        async function loadStats() {
            const getStats = functions.httpsCallable('getStats');
            try {
                const result = await getStats();
                const data = result.data;
                
                document.getElementById('status').innerHTML = data.connected ? 
                    (data.qualified ? '✅ Qualified! (100+ likes post)' : '⚠️ Connected but no 100+ like post yet') :
                    '❌ Facebook not connected';
                document.getElementById('best-likes').textContent = data.bestPostLikes || 0;
                document.getElementById('total-earned').textContent = `$${data.totalEarned?.toFixed(2) || '0.00'}`;
                document.getElementById('pending-balance').textContent = `$${data.pendingBalance?.toFixed(2) || '0.00'}`;
                
                if (data.connected && data.qualified) {
                    document.getElementById('connect-section').style.display = 'none';
                    document.getElementById('campaigns-section').style.display = 'block';
                    document.getElementById('ad-submit-section').style.display = 'block';
                    document.getElementById('earnings-section').style.display = 'block';
                    
                    availableCampaigns = data.campaigns || [];
                    displayCampaigns(availableCampaigns);
                    displayEarnings(data.recentEarnings || []);
                    updateCampaignSelect();
                } else if (data.connected && !data.qualified) {
                    document.getElementById('connect-section').innerHTML = `
                        <h2>⚠️ Need More Engagement</h2>
                        <p>You need a post with 100+ likes. Your best post has ${data.bestPostLikes || 0} likes.</p>
                        <button onclick="refreshFacebookData()">Refresh Data</button>
                    `;
                }
            } catch(err) {
                console.error(err);
                document.getElementById('status').innerHTML = 'Error loading stats';
            }
        }
        
        async function connectFacebook() {
            const redirectUri = encodeURIComponent(window.location.origin + '/dashboard.html');
            const fbAuthUrl = `https://www.facebook.com/v18.0/dialog/oauth?client_id=${FB_APP_ID}&redirect_uri=${redirectUri}&scope=pages_show_list,posts_read,pages_read_engagement`;
            window.location.href = fbAuthUrl;
        }
        
        const urlParams = new URLSearchParams(window.location.search);
        const code = urlParams.get('code');
        if (code) {
            const connectFacebookFn = functions.httpsCallable('connectFacebook');
            connectFacebookFn({ fbAuthCode: code }).then(result => {
                if (result.data.qualified) {
                    alert(`Success! You're qualified with ${result.data.likeCount} likes on your best post.`);
                } else {
                    alert(`Connected but you need a post with 100+ likes. Your best post has ${result.data.likeCount} likes.`);
                }
                window.history.replaceState({}, document.title, window.location.pathname);
                loadStats();
            }).catch(err => {
                alert('Error connecting Facebook: ' + err.message);
            });
        }
        
        async function refreshFacebookData() {
            const refreshFn = functions.httpsCallable('refreshFacebookData');
            const result = await refreshFn();
            if (result.data.qualified) {
                alert(`Great news! You now qualify with ${result.data.bestPostLikes} likes!`);
            } else {
                alert(`Still need more likes. Current best: ${result.data.bestPostLikes} likes`);
            }
            loadStats();
        }
        
        function displayCampaigns(campaigns) {
            const container = document.getElementById('campaigns-list');
            if (!campaigns.length) {
                container.innerHTML = '<p>No active campaigns right now. Check back soon!</p>';
                return;
            }
            container.innerHTML = campaigns.map(c => `
                <div class="campaign-card">
                    <strong>${c.brandName}</strong>
                    <p>Payout: $${c.payoutPerLike} per like</p>
                    <p>Budget remaining: $${c.remainingBudget?.toFixed(2)}</p>
                </div>
            `).join('');
        }
        
        function updateCampaignSelect() {
            const select = document.getElementById('campaign-select');
            select.innerHTML = availableCampaigns.map(c => 
                `<option value="${c.id}">${c.brandName} - $${c.payoutPerLike}/like</option>`
            ).join('');
        }
        
        async function submitAd() {
            const campaignId = document.getElementById('campaign-select').value;
            const postUrl = document.getElementById('post-url').value;
            if (!postUrl) {
                alert('Please paste your Facebook post URL');
                return;
            }
            const submitFn = functions.httpsCallable('submitAdPost');
            try {
                const result = await submitFn({ campaignId, postUrl });
                document.getElementById('submit-status').innerHTML = '<p style="color:green;">✅ ' + result.data.message + '</p>';
                document.getElementById('post-url').value = '';
            } catch(err) {
                document.getElementById('submit-status').innerHTML = '<p style="color:red;">❌ ' + err.message + '</p>';
            }
        }
        
        function displayEarnings(earnings) {
            const container = document.getElementById('earnings-list');
            if (!earnings.length) {
                container.innerHTML = '<p>No earnings yet. Submit an ad to start earning!</p>';
                return;
            }
            container.innerHTML = `
                <table class="earnings-table">
                    <tr><th>Date</th><th>Likes Generated</th><th>Amount</th></tr>
                    ${earnings.map(e => `
                        <tr>
                            <td>${new Date(e.paidAt?.toDate()).toLocaleDateString()}</td>
                            <td>${e.likesGenerated || 0}</td>
                            <td>$${(e.amountPaid || 0).toFixed(2)}</td>
                        </tr>
                    `).join('')}
                </table>
            `;
        }
        
        async function requestWithdrawal() {
            const withdrawFn = functions.httpsCallable('requestWithdrawal');
            try {
                const result = await withdrawFn();
                alert(`Withdrawal of $${result.data.amount} requested! ${result.data.message}`);
                loadStats();
            } catch(err) {
                alert('Withdrawal failed: ' + err.message);
            }
        }
        
        function logout() {
            auth.signOut();
            window.location.href = 'index.html';
        }
    </script>
</body>
</html>